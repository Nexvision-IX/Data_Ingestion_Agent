# AWS deployment template. Copy to .env on EC2 and replace placeholders.
# Never commit the populated .env file.

APP_NAME=AI AP Agent
APP_ENV=aws

# EC2 service ports. DNS is not required for the initial deployment.
FRONTEND_PORT=3000
SAP_API_PORT=3003
AGENT_API_PORT=3006

# Internal communication while all services run on the same EC2 instance.
MOCK_API_BASE_URL=http://127.0.0.1:3003
AP_AGENT_BASE_URL=http://127.0.0.1:3006
SAP_BASE_URL=http://127.0.0.1:3003
KEFRON_BASE_URL=http://127.0.0.1:3003
POSTED_INVOICE_API_BASE_URL=http://127.0.0.1:3003

# Optional future public URLs after DNS and TLS are ready:
# FRONTEND_PUBLIC_URL=http://agentic-ap.nexvisionix.com:3000
# SAP_API_PUBLIC_URL=http://sap-api.nexvisionix.com:3003
# AGENT_API_PUBLIC_URL=http://ap-agent-api.nexvisionix.com:3006

# PostgreSQL RDS URLs are mandatory in APP_ENV=aws. URL-encode credentials.
DATABASE_URL=postgresql+psycopg://REPLACE_USER:REPLACE_PASSWORD@REPLACE_RDS_HOST:5432/REPLACE_DATABASE?sslmode=require
MASTER_DATABASE_URL=postgresql+psycopg://REPLACE_USER:REPLACE_PASSWORD@REPLACE_RDS_HOST:5432/REPLACE_DATABASE?sslmode=require

# Mock SAP/Kefron credentials. Replace all placeholders on EC2.
SAP_USERNAME=REPLACE_ME
SAP_PASSWORD=REPLACE_ME
KEFRON_API_KEY=REPLACE_ME

# Agent integration.
SAP_PROVIDER=ap_master
POSTED_INVOICE_API_ENABLED=true
POSTED_INVOICE_API_USERNAME=REPLACE_ME
POSTED_INVOICE_API_PASSWORD=REPLACE_ME

# OCR/LLM configuration.
GROQ_API_KEY=REPLACE_ME
LLM_PROVIDER=mock
LLM_API_KEY=
LLM_MODEL=mock-model

# S3 configuration readiness. EC2 should use its IAM role; do not add static
# AWS access keys. Full artifact upload/download behavior is a later step.
STORAGE_BACKEND=s3
S3_BUCKET_NAME=nvx-agentic-ap-invoice-data
S3_REGION=REPLACE_WITH_BUCKET_REGION
AWS_REGION=REPLACE_WITH_BUCKET_REGION
# # Root prefix only. Steps 15A-15C create hierarchical artifact storage.
# invoices/{invoice_number_or_upload_id}/... keys below this prefix.
S3_PREFIX=ap-demo/
S3_ENDPOINT_URL=
AWS_PROFILE=

# Local working directories used while processing files.
UNSTRUCTURED_INPUT_DIR=./unstructured_ingestion/unstructured_inputs
STORAGE_PATH=./storage

# Safe demo email defaults.
SMTP_DRY_RUN=true
AUTO_SEND_EMAIL=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true
SMTP_USE_SSL=false
AP_EXCEPTION_RECIPIENT=

# Workflow controls.
AUTO_POST_CLEAN_INVOICES=true
PRICE_TOLERANCE_PERCENT=2.0
RECHECK_MAX_ATTEMPTS=3

# These must remain false in AWS unless an intentional one-time maintenance
# operation has been approved.
AUTO_CREATE_AGENT_TABLES=false
ALLOW_DESTRUCTIVE_AGENT_RESET=false
ALLOW_DESTRUCTIVE_MASTER_RESET=false
