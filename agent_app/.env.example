# Agent API settings. Copy to agent_app/.env for local use only.
# Never commit populated credentials.

APP_NAME=AI AP Agent
APP_ENV=development

# Local service ports.
FRONTEND_PORT=8501
SAP_API_PORT=8001
AGENT_API_PORT=8000

# Local SQLite databases (paths are relative to agent_app/).
DATABASE_URL=sqlite:///./ap_agent.db
MASTER_DATABASE_URL=sqlite:///../data/master/ap_master.db

# AWS/RDS alternative. Inject real credentials with AWS Secrets Manager or SSM.
# APP_ENV=aws
# DATABASE_URL=postgresql+psycopg://agent_user:REPLACE_ME@db.example.internal:5432/ap_automation?sslmode=require
# MASTER_DATABASE_URL=postgresql+psycopg://master_user:REPLACE_ME@db.example.internal:5432/ap_automation?sslmode=require

SAP_PROVIDER=ap_master
MOCK_API_BASE_URL=http://127.0.0.1:8001
AP_AGENT_BASE_URL=http://127.0.0.1:8000
SAP_BASE_URL=http://127.0.0.1:8001
KEFRON_BASE_URL=http://127.0.0.1:8001
API_BASE_URL=http://127.0.0.1:8000
POSTED_INVOICE_API_ENABLED=true
POSTED_INVOICE_API_BASE_URL=http://127.0.0.1:8001
POSTED_INVOICE_API_USERNAME=REPLACE_ME
POSTED_INVOICE_API_PASSWORD=REPLACE_ME

# Storage configuration. Full S3 artifact storage is not implemented yet.
STORAGE_BACKEND=local
STORAGE_PATH=./storage
S3_BUCKET_NAME=
S3_REGION=
AWS_REGION=
S3_PREFIX=ap-demo/
S3_ENDPOINT_URL=
# AWS_PROFILE is optional for local AWS testing. EC2 should use an IAM role.
AWS_PROFILE=

# LLM is advisory only: classification, communication drafting, and recheck
# summarization. Deterministic controls remain authoritative for approval.
LLM_PROVIDER=mock
LLM_API_KEY=
LLM_MODEL=
# Optional for compatible/self-hosted endpoints. Groq uses its default when blank.
LLM_BASE_URL=
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=2

# Email remains non-sending by default.
SMTP_DRY_RUN=true
AUTO_SEND_EMAIL=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true
SMTP_USE_SSL=false
AP_EXCEPTION_RECIPIENT=

# Local workflow controls.
AUTO_POST_CLEAN_INVOICES=true
PRICE_TOLERANCE_PERCENT=2.0
FINANCIAL_TOLERANCE_AMOUNT=0.01
TAX_TOLERANCE_AMOUNT=0.01
MAX_INVOICE_AGE_DAYS=365
RECHECK_MAX_ATTEMPTS=3
MIN_EXTRACTION_CONFIDENCE=0.80
EXTRACTION_RECONCILIATION_TOLERANCE=0.01
EXTRACTION_MAX_RETRY_ATTEMPTS=1

# LOCAL SQLITE DEMO ONLY. Keep all three false/omitted for PostgreSQL/RDS.
AUTO_CREATE_AGENT_TABLES=true
ALLOW_DESTRUCTIVE_AGENT_RESET=true
ALLOW_DESTRUCTIVE_MASTER_RESET=true
# AUTO_CREATE_AGENT_TABLES=false
# ALLOW_DESTRUCTIVE_AGENT_RESET=false
# ALLOW_DESTRUCTIVE_MASTER_RESET=false

# Legacy AP_MASTER_DB_PATH is intentionally omitted. Use MASTER_DATABASE_URL.
